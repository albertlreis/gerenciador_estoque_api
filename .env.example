APP_NAME=Laravel
APP_ENV=local
APP_SERVICE=gerenciador-estoque-api
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
API_RATE_LIMIT_PER_MINUTE=600
CLIENT_LOG_RATE_LIMIT_PER_MINUTE=120
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Provedores
HOLIDAYS_PRIMARY=brasilapi
HOLIDAYS_FALLBACK=nager
HOLIDAYS_STATE_PROVIDER=calendarific

# UF padrão do seu negócio (para estaduais)
HOLIDAYS_DEFAULT_UF=PA

# Calendarific
CALENDARIFIC_API_KEY=chave
INVERTEXTO_TOKEN=chave

SERVICES_EXTRATOR_PEDIDO_URL=http://leitor-pdf-sierra:8000/extrair-pedido
SERVICES_EXTRATOR_PEDIDO_FORCE_LOCAL_URL=false
COMMS_BASE_URL=http://api-comunicacao:8002/api
COMMS_API_KEY=chave
COMMS_API_SECRET=chave

SIERRA_TEMPLATE_CODE_PEDIDO_STATUS_EMAIL=sierra_pedido_status_email
SIERRA_TEMPLATE_CODE_COBRANCA_SMS=sierra_cobranca_sms
SIERRA_TEMPLATE_CODE_COBRANCA_WPP=sierra_cobranca_whatsapp

# Conta Azul OAuth
# Para app de desenvolvimento da Conta Azul, use fluxo local/manual e NUNCA versione o client_secret.
# O callback local do nosso backend nao e o fluxo recomendado para esse app dev.
CONTA_AZUL_CLIENT_ID=
CONTA_AZUL_CLIENT_SECRET=
CONTA_AZUL_REDIRECT_URI=http://localhost:8004/api/v1/integrations/conta-azul/callback
CONTA_AZUL_AUTH_URL=https://auth.contaazul.com
CONTA_AZUL_AUTHORIZE_PATH=/login
CONTA_AZUL_TOKEN_PATH=/oauth2/token
CONTA_AZUL_BASE_URL=https://api-v2.contaazul.com
CONTA_AZUL_SCOPE="openid profile aws.cognito.signin.user.admin"
CONTA_AZUL_OAUTH_FRONT_REDIRECT=http://localhost:5173/integracoes/conta-azul

# Banco do Brasil - API de Extratos
BB_EXTRATOS_ENABLED=false
BB_EXTRATOS_ENV=producao
BB_EXTRATOS_CLIENT_ID=
BB_EXTRATOS_CLIENT_SECRET=
BB_EXTRATOS_APP_KEY=
BB_EXTRATOS_OAUTH_URL=https://oauth.bb.com.br/oauth/token
BB_EXTRATOS_BASE_URL=https://api.bb.com.br
BB_EXTRATOS_STATEMENT_PATH=/extratos/v1/conta-corrente/agencia/{agencia}/conta/{conta}
BB_EXTRATOS_APP_KEY_PARAM=gw-dev-app-key
BB_EXTRATOS_SCOPE=extrato-info

# Google Agenda OAuth
# Cadastre esta URL como Authorized redirect URI no Google Cloud Console.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8004/api/v1/integrations/google-calendar/callback
GOOGLE_CALENDAR_OAUTH_FRONT_REDIRECT=http://localhost:5173/integracoes/google-agenda
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo
GOOGLE_CALENDAR_CACHE_TTL_SECONDS=90
